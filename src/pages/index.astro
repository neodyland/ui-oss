---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/shadcn/ui/button";
import { Image } from "astro:assets";

import brandText from "../assets/brand-text.png";

import { TbBrandFramerMotion } from "react-icons/tb";
import { SiRadixui, SiShadcnui, SiTailwindcss } from "react-icons/si";
---

<Layout title="Neody UI">
    <div class="flex flex-col items-center justify-center min-h-screen">
        <div class="flex flex-col items-center text-center">
            <h1 class="text-4xl font-bold mt-4">Simple, unopiniated UI components for your apps</h1>
            <div class="flex flex-row items-center justify-center space-x-3 mt-5">
                <h3 class="text-lg">Powered by</h3>
                <TbBrandFramerMotion className="text-xl text-gray-500" />
                <SiTailwindcss className="text-xl text-gray-500" />
                <SiShadcnui className="text-xl text-gray-500" />
                <SiRadixui className="text-xl text-gray-500" />
            </div>
            <p class="text-lg mt-5">by</p>
            <a href="https://neody.land/">
            <div class="flex flex-row items-center space-x-5 mt-1">
                <Image src={brandText} alt="Neody UI" class="w-24 h-full" />
            </div>
            </a>
            <div class="mt-4 flex flex-row space-x-2">
                <a href="/components">
                    <Button className="bg-[#3CF6E7] w-48">Browse components</Button>
                </a>
                <a href="/docs">
                    <Button className="bg-[#711BE773] w-48">Go to documentation</Button>
                </a>
            </div>
        </div>
    </div>
</Layout>